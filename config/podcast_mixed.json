{
  "description": "Mixed-Format Podcast – dynamisch und vielseitig",
  "audio_file": "input.mp3",
  "output_file": "podcast_mixed.mp4",
  "visual": {
    "type": "neon_wave_circle",
    "resolution": [1920, 1080],
    "fps": 30,
    "colors": {
      "primary": "#2ECC71",
      "secondary": "#1ABC9C",
      "background": "#0A0A0A"
    },
    "params": {
      "circle_count": 4,
      "wave_amplitude": 0.9
    }
  },
  "postprocess": {
    "contrast": 1.1,
    "saturation": 1.0,
    "grain": 0.02,
    "vignette": 0.2,
    "chromatic_aberration": 0.0
  }
}
